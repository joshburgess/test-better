# Force LF line endings for every text file in the repo, on every platform.
# Without this, git's default `core.autocrlf=true` on Windows rewrites text
# files to CRLF on checkout, which breaks any test that compares against a
# byte-exact golden / snapshot fixture.
*           text=auto eol=lf

# Snapshot and golden fixtures are the explicit reason this file exists: they
# are compared byte-for-byte against the in-memory rendered value. Pin them
# even if the global rule above is ever loosened.
*.snap      text eol=lf
*.patch     text eol=lf
*.txt       text eol=lf
